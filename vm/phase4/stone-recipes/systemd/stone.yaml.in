name        : systemd
version     : @SYSTEMD_VERSION@
release     : 1
summary     : Bootstrap systemd userspace payload for ONIX
license     : LGPL-2.1-or-later
homepage    : https://systemd.io/
upstreams   :
    - @SYSTEMD_PAYLOAD_URL@: @SYSTEMD_PAYLOAD_SHA256@
provides-exclude:
    - '^soname\(onix/bootstrap/nix/store/.*'
    - '^pkgconfig\(.*\)$'
rundeps-exclude:
    - '^interpreter\(/nix/store/.*'
    - '^soname\(.*\(x86_64\)\)$'
description : |
    Bootstrap ONIX systemd userspace payload.

    This first systemd stone packages the currently proven musl systemd
    payload and its runtime closure so ONIX has a moss-owned machine-plane
    package boundary before the later native recipe work.

    Build provenance: pinned nixpkgs pkgsMusl.systemd
    Systemd output  : @SYSTEMD_PAYLOAD_OUT@
    Closure entries : @SYSTEMD_CLOSURE_COUNT@
    Bootstrap store : /usr/lib/onix/bootstrap/nix/store

    This is not the final source-native ONIX systemd recipe. It is the first
    honest ownership stone for the exact payload Phase 213/414 proved.
install     : |
    install -dm00755 %(installroot)
    cp -a usr %(installroot)/

    chmod 00755 %(installroot)/usr
    chmod 00755 %(installroot)/usr/bin
    chmod 00755 %(installroot)/usr/lib
    chmod 00755 %(installroot)/usr/lib/systemd
    chmod 00755 %(installroot)/usr/lib/onix
    chmod 00755 %(installroot)/usr/lib/onix/bootstrap
    chmod 00755 %(installroot)/usr/lib/onix/bootstrap/nix
    chmod 00755 %(installroot)/usr/lib/onix/bootstrap/nix/store
    chmod 00755 %(installroot)/usr/share
    chmod 00755 %(installroot)/usr/share/onix
    chmod 00755 %(installroot)/usr/share/onix/packages
    chmod 0644 \
        %(installroot)/usr/share/onix/packages/systemd.md \
        %(installroot)/usr/share/onix/packages/systemd.closure \
        %(installroot)/usr/share/onix/packages/systemd.links

    # Boulder packages /usr payload. The Nix closure is carried under a
    # package-owned bootstrap area and Phase 416 materializes it to /nix/store
    # for the absolute musl loader/runtime paths.
    #
    # Boulder build dirs inherit setgid. Clear it on directories we create so
    # Moss receives ordinary directory layout metadata. The bootstrap store's
    # directory modes were already normalized during staging so non-root extract
    # and disposable install checks can create child paths safely.
    chmod g-s \
        %(installroot)/usr \
        %(installroot)/usr/bin \
        %(installroot)/usr/lib \
        %(installroot)/usr/lib/systemd \
        %(installroot)/usr/lib/onix \
        %(installroot)/usr/lib/onix/bootstrap \
        %(installroot)/usr/lib/onix/bootstrap/nix \
        %(installroot)/usr/lib/onix/bootstrap/nix/store \
        %(installroot)/usr/share \
        %(installroot)/usr/share/onix \
        %(installroot)/usr/share/onix/packages
