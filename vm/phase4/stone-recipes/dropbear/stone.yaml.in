name        : dropbear
version     : @DROPBEAR_VERSION@
release     : 1
summary     : Static Dropbear SSH server for ONIX bootstrap images
license     : MIT
homepage    : https://matt.ucc.asn.au/dropbear/dropbear.html
upstreams   :
    - @DROPBEAR_PAYLOAD_URL@: @DROPBEAR_PAYLOAD_SHA256@
description : |
    Musl-static Dropbear SSH server payload for early ONIX remote-access proofs.

    The Dropbear source is built in the Alpine/musl forge VM first. Boulder then
    packages that prepared payload into a .stone, making it moss-installable.

    Source archive: @DROPBEAR_SOURCE_ARCHIVE@
    Source SHA-256: @DROPBEAR_SOURCE_SHA256@
install     : |
    install -dm00755 %(installroot)
    cp -a usr %(installroot)/

    chmod 00755 %(installroot)/usr
    chmod 00755 %(installroot)/usr/bin
    chmod 00755 %(installroot)/usr/sbin
    chmod 00755 %(installroot)/usr/share
    chmod 00755 %(installroot)/usr/share/onix
    chmod 00755 %(installroot)/usr/share/onix/packages
    chmod 00755 \
        %(installroot)/usr/sbin/dropbear \
        %(installroot)/usr/bin/dropbearkey
    chmod 0644 %(installroot)/usr/share/onix/packages/dropbear.md

    # Boulder build dirs inherit setgid. Clear it on directories we created so
    # Moss receives ordinary directory layout metadata.
    chmod g-s \
        %(installroot)/usr \
        %(installroot)/usr/bin \
        %(installroot)/usr/sbin \
        %(installroot)/usr/share \
        %(installroot)/usr/share/onix \
        %(installroot)/usr/share/onix/packages
