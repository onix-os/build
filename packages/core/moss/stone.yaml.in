name        : moss
version     : "@MOSS_VERSION@"
release     : @MOSS_RELEASE@
homepage    : https://github.com/AerynOS/os-tools
summary     : ONIX package and state manager
description : |
    moss is the ONIX runtime package/state manager.

    Phase 515 packages moss as an ONIX-owned Rust/musl system package so the
    booted machine can consume an ONIX repository from inside the VM.

    Source commit: @OS_TOOLS_COMMIT@
license     :
    - MPL-2.0
upstreams   :
    - "@MOSS_PAYLOAD_URL@" : "@MOSS_PAYLOAD_SHA256@"
builddeps   : []
install     : |
    install -dm00755 %(installroot)/usr
    cp -a usr/. %(installroot)/usr/

    chmod 00755 %(installroot)/usr
    chmod 00755 %(installroot)/usr/bin
    chmod 00755 %(installroot)/usr/bin/moss
    chmod 00755 %(installroot)/usr/share
    chmod 00755 %(installroot)/usr/share/onix
    chmod 00755 %(installroot)/usr/share/onix/packages
    chmod 0644 %(installroot)/usr/share/onix/packages/moss.md

    find %(installroot)/usr -type d -exec chmod g-s {} \;
