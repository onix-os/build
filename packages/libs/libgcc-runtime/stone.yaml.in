name        : libgcc-runtime
version     : "@LIBGCC_RUNTIME_VERSION@"
release     : 1
summary     : ONIX-owned GCC runtime shared object
license     : GPL-3.0-or-later WITH GCC-exception-3.1
homepage    : https://gcc.gnu.org/
upstreams   :
    - "@LIBGCC_RUNTIME_PAYLOAD_URL@" : "@LIBGCC_RUNTIME_PAYLOAD_SHA256@"
description : |
    Minimal ONIX-owned libgcc_s runtime surface.

    This stone owns the libgcc_s.so.1 soname required by the current RootAsRole
    Rust/musl build. It is a bootstrap toolchain-runtime package until ONIX has
    a fuller source-built compiler runtime.

    Source/provenance note: @LIBGCC_RUNTIME_SOURCE_NOTE@
install     : |
    install -dm00755 %(installroot)
    cp -a usr %(installroot)/

    chmod 00755 %(installroot)/usr
    chmod 00755 %(installroot)/usr/lib
    chmod 00755 %(installroot)/usr/share
    chmod 00755 %(installroot)/usr/share/onix
    chmod 00755 %(installroot)/usr/share/onix/packages
    chmod 0644 %(installroot)/usr/share/onix/packages/libgcc-runtime.md
