name        : musl
version     : @MUSL_VERSION@
release     : 1
summary     : ONIX-owned musl runtime provider
license     : MIT
homepage    : https://musl.libc.org/
upstreams   :
    - @MUSL_PAYLOAD_URL@: @MUSL_PAYLOAD_SHA256@
description : |
    musl libc runtime provider for ONIX dynamic-musl packages.

    This stone provides the musl loader/libc soname needed by intentional
    dynamic-musl package surfaces such as linux-pam and libseccomp.

    Source archive: @MUSL_SOURCE_ARCHIVE@
    Source SHA-256: @MUSL_SOURCE_SHA256@
install     : |
    install -dm00755 %(installroot)
    cp -a usr %(installroot)/

    chmod 00755 %(installroot)/usr
    chmod 00755 %(installroot)/usr/lib
    chmod 00755 %(installroot)/usr/share
    chmod 00755 %(installroot)/usr/share/onix
    chmod 00755 %(installroot)/usr/share/onix/packages
    chmod 0644 %(installroot)/usr/share/onix/packages/musl.md
