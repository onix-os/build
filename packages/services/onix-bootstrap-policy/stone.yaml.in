name        : onix-bootstrap-policy
version     : @BOOTSTRAP_POLICY_VERSION@
release     : 1
summary     : Bootstrap service policy and helper scripts for ONIX
license     : LicenseRef-ONIX-bootstrap-policy
homepage    : https://github.com/onix-os
upstreams   :
    - @BOOTSTRAP_POLICY_PAYLOAD_URL@: @BOOTSTRAP_POLICY_PAYLOAD_SHA256@
description : |
    Package-owned ONIX bootstrap policy.

    This package owns the scripts, proof notes, and source copies of the
    temporary bootstrap systemd units used while Phase 4 brings the base system
    into shape.

    It is not the final service architecture. It moves the policy source out of
    image-assembly shell heredocs and into a moss-installable .stone.
install     : |
    install -dm00755 %(installroot)
    cp -a usr %(installroot)/

    chmod 00755 %(installroot)/usr
    chmod 00755 %(installroot)/usr/lib
    chmod 00755 %(installroot)/usr/lib/onix
    chmod 00755 %(installroot)/usr/lib/onix/systemd
    chmod 00755 %(installroot)/usr/lib/onix/systemd/system
    chmod 00755 %(installroot)/usr/share
    chmod 00755 %(installroot)/usr/share/onix
    chmod 00755 %(installroot)/usr/share/onix/bootstrap
    chmod 00755 %(installroot)/usr/share/onix/packages
    chmod 00755 \
        %(installroot)/usr/lib/onix/bootstrap-network-proof \
        %(installroot)/usr/lib/onix/bootstrap-network-status \
        %(installroot)/usr/lib/onix/bootstrap-network-up \
        %(installroot)/usr/lib/onix/bootstrap-remote-inspection-proof \
        %(installroot)/usr/lib/onix/bootstrap-remote-inspection-response \
        %(installroot)/usr/lib/onix/bootstrap-remote-inspection-status \
        %(installroot)/usr/lib/onix/bootstrap-serial-shell \
        %(installroot)/usr/lib/onix/bootstrap-ssh-proof \
        %(installroot)/usr/lib/onix/bootstrap-ssh-status
    chmod 0644 \
        %(installroot)/usr/lib/onix/systemd/system/onix-bootstrap-dropbear.service \
        %(installroot)/usr/lib/onix/systemd/system/onix-bootstrap-network.service \
        %(installroot)/usr/lib/onix/systemd/system/onix-bootstrap-remote-inspection.service \
        %(installroot)/usr/lib/onix/systemd/system/onix-bootstrap-serial-shell.service \
        %(installroot)/usr/share/onix/bootstrap/bootstrap-policy.txt \
        %(installroot)/usr/share/onix/bootstrap/dropbear-stone.txt \
        %(installroot)/usr/share/onix/bootstrap/networking.txt \
        %(installroot)/usr/share/onix/bootstrap/remote-inspection.txt \
        %(installroot)/usr/share/onix/bootstrap/serial-console.txt \
        %(installroot)/usr/share/onix/bootstrap/ssh.txt \
        %(installroot)/usr/share/onix/packages/onix-bootstrap-policy.md

    # Boulder build dirs inherit setgid. Clear it on directories we created so
    # Moss receives ordinary directory layout metadata.
    chmod g-s \
        %(installroot)/usr \
        %(installroot)/usr/lib \
        %(installroot)/usr/lib/onix \
        %(installroot)/usr/lib/onix/systemd \
        %(installroot)/usr/lib/onix/systemd/system \
        %(installroot)/usr/share \
        %(installroot)/usr/share/onix \
        %(installroot)/usr/share/onix/bootstrap \
        %(installroot)/usr/share/onix/packages
